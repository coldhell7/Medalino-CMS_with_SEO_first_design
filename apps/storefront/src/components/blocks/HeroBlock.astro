---
export interface Props {
  kicker: string;
  title: string;
  lead: string;
  image: string;
  imageAlt: string;
  badgeText: string;
  badgeDesc: string;
  buttons: Array<{ label: string; href: string; variant: string }>;
}

const { kicker, title, lead, image, imageAlt, badgeText, badgeDesc, buttons } = Astro.props;
---

<section class="hero">
  <div class="hero__mesh" aria-hidden="true"></div>
  <div class="hero__inner">
    <div class="hero__copy">
      <span class="hero__kicker">{kicker}</span>
      <h1 class="hero__title">{title}</h1>
      <p class="hero__lead">{lead}</p>
      <div class="hero__actions">
        {buttons.map((btn) => (
          <a href={btn.href} class={`btn btn--${btn.variant}`}>{btn.label}</a>
        ))}
      </div>
    </div>
    <div class="hero__visual">
      <div class="hero__frame">
        <img
          src={image}
          alt={imageAlt}
          width="1200"
          height="675"
          loading="eager"
          fetchpriority="high"
          decoding="sync"
          referrerpolicy="no-referrer-when-downgrade"
          class="hero__img"
        />
        <div class="hero__badge">
          <strong>{badgeText}</strong>
          <span>{badgeDesc}</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    padding: clamp(2.5rem, 6vw, 4.5rem) var(--space-4) clamp(2rem, 5vw, 3.5rem);
  }
  .hero__mesh {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 55% at 100% 0%, rgba(45, 212, 191, 0.22), transparent 50%),
      radial-gradient(ellipse 60% 50% at 0% 100%, rgba(14, 165, 233, 0.18), transparent 45%),
      linear-gradient(180deg, #f8fafc 0%, #f1f5f9 100%);
    pointer-events: none;
  }
  .hero__inner {
    position: relative;
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    gap: var(--space-8);
    grid-template-columns: 1.02fr 0.98fr;
    align-items: center;
  }
  .hero__kicker {
    display: inline-block;
    margin: 0 0 12px;
    padding: 6px 12px;
    border-radius: 999px;
    background: rgba(13, 148, 136, 0.12);
    color: #0f766e;
    font-weight: 800;
    font-size: var(--text-sm);
  }
  .hero__title {
    margin: 0 0 var(--space-4);
    font-size: clamp(2rem, 4.5vw, 3.15rem);
    line-height: 1.18;
    font-weight: 900;
    letter-spacing: -0.02em;
    color: var(--text);
    min-height: 1.18em;
  }
  .hero__lead {
    margin: 0 0 var(--space-6);
    color: var(--text-muted);
    font-size: clamp(1rem, 2vw, 1.15rem);
    max-width: 48ch;
    line-height: 1.85;
  }
  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 14px 22px;
    border-radius: 14px;
    font-weight: 800;
    font-size: var(--text-sm);
    text-decoration: none;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }
  .btn--primary {
    background: var(--accent);
    color: var(--accent-foreground);
    box-shadow: 0 10px 28px rgba(13, 148, 136, 0.35);
  }
  .btn--ghost {
    border: 1px solid var(--border);
    color: var(--text);
    background: var(--bg);
  }
  .btn:hover {
    transform: translateY(-2px);
  }
  .hero__frame {
    position: relative;
    border-radius: 22px;
    overflow: hidden;
    border: 1px solid var(--border);
    box-shadow: 0 24px 60px rgba(15, 23, 42, 0.12);
    background: #0f172a;
  }
  .hero__img {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
  }
  .hero__badge {
    position: absolute;
    inset-inline: 16px;
    inset-block-end: 16px;
    padding: 14px 16px;
    border-radius: 14px;
    background: rgba(15, 23, 42, 0.78);
    color: #f8fafc;
    font-size: var(--text-sm);
    backdrop-filter: blur(8px);
    display: flex;
    flex-direction: column;
    gap: 4px;
    max-width: min(380px, 100%);
  }
  .hero__badge strong { font-size: var(--text-sm); }
  .hero__badge span { opacity: 0.92; line-height: 1.5; }
  @media (max-width: 900px) {
    .hero__inner { grid-template-columns: 1fr; }
  }
</style>
