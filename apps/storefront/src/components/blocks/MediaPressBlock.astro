---
export interface Props {
  title: string;
  items: Array<{ name: string; logo: string; url: string; quote: string }>;
}

const { title, items } = Astro.props;
---

<section class="media-press">
  <div class="section__inner">
    <span class="section__eyebrow">رسانه‌ها</span>
    <h2 class="media-press__title">{title}</h2>
    <div class="media-press__grid">
      {items.map((item) => (
        <a href={item.url} target="_blank" rel="noopener noreferrer" class="press-card">
          <div class="press-card__logo">
            <img src={item.logo} alt={item.name} width="80" height="80" loading="lazy" decoding="async" />
          </div>
          <strong class="press-card__name">{item.name}</strong>
          <p class="press-card__quote">{item.quote}</p>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .media-press {
    background: var(--bg);
    border-block: 1px solid var(--border);
    padding: clamp(2.5rem, 5vw, 3.5rem) var(--space-4);
  }
  .section__inner { max-width: 1100px; margin: 0 auto; text-align: center; }
  .section__eyebrow {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: 800;
    color: var(--accent);
    letter-spacing: 0.04em;
    margin-bottom: 6px;
  }
  .media-press__title {
    margin: 0 0 var(--space-6);
    font-size: clamp(1.35rem, 2.5vw, 1.7rem);
    font-weight: 900;
  }
  .media-press__grid {
    display: grid;
    gap: var(--space-4);
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  }
  .press-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    padding: var(--space-5);
    border-radius: var(--radius-lg);
    border: 1px solid var(--border);
    background: var(--bg-elevated);
    text-decoration: none;
    color: inherit;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }
  .press-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(15, 23, 42, 0.08);
  }
  .press-card__logo {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background: var(--surface);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .press-card__logo img { width: 60px; height: 60px; object-fit: contain; }
  .press-card__name { font-size: var(--text-sm); color: var(--text); }
  .press-card__quote {
    margin: 0;
    font-size: var(--text-xs);
    color: var(--text-muted);
    line-height: 1.6;
  }
</style>
