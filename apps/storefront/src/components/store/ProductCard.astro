---
import type { CatalogProduct } from "../../data/catalog";
import { formatToman } from "../../data/catalog";

type Props = { product: CatalogProduct };

const { product } = Astro.props;
const href = `/products/${product.slug}`;
---

<a
  href={href}
  class="product-card"
  style="display:flex;flex-direction:column;text-decoration:none;color:inherit;border-radius:var(--radius-lg);border:1px solid var(--border);background:var(--bg);overflow:hidden;transition:box-shadow 0.2s, transform 0.2s;"
>
  <div style="position:relative;aspect-ratio:1/1;background:var(--bg-muted);overflow:hidden;">
    <img
      src={product.image}
      alt={product.imageAlt}
      width="800"
      height="800"
      loading="lazy"
      decoding="async"
      referrerpolicy="no-referrer-when-downgrade"
      style="width:100%;height:100%;object-fit:cover;display:block;"
    />
    {
      product.featured ? (
        <span
          style="position:absolute;top:12px;inset-inline-start:12px;background:#f59e0b;color:#1c1917;font-size:var(--text-xs);font-weight:800;padding:6px 10px;border-radius:999px;box-shadow:0 2px 8px rgba(0,0,0,0.15);"
        >
          ویژه
        </span>
      ) : null
    }
    {
      product.badge ? (
        <span
          style="position:absolute;top:12px;inset-inline-end:12px;background:var(--accent);color:var(--accent-foreground);font-size:var(--text-xs);font-weight:700;padding:6px 10px;border-radius:999px;"
        >
          {product.badge}
        </span>
      ) : null
    }
  </div>
  <div style="padding:var(--space-4);display:flex;flex-direction:column;gap:var(--space-2);flex:1;">
    <h3 style="margin:0;font-size:var(--text-base);font-weight:700;line-height:1.35;">{product.name}</h3>
    <p style="margin:0;color:var(--text-muted);font-size:var(--text-sm);line-height:1.5;flex:1;">{product.summary}</p>
    <div style="display:flex;align-items:center;justify-content:space-between;gap:var(--space-3);margin-top:auto;">
      <span style="font-weight:800;font-size:var(--text-lg);color:var(--text);">{formatToman(product.priceToman)}</span>
      <span style="font-size:var(--text-xs);color:var(--text-muted);">
        ★ {product.rating.toLocaleString("fa-IR")} ({product.reviewCount.toLocaleString("fa-IR")})
      </span>
    </div>
  </div>
</a>

<style>
  .product-card:hover {
    box-shadow: var(--shadow-2);
    transform: translateY(-2px);
  }
</style>
