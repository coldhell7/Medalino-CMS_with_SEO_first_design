---
type Props = {
  title: string;
  subtitle: string;
  hue: number;
  gid: string;
  /** Optional thematic cover photo (sample stock). */
  coverImage?: string;
};
const { title, subtitle, hue, gid, coverImage } = Astro.props;
const gradId = `g-${gid}`;
---

<div
  class="cat-tile"
  style="border-radius:var(--radius-lg);border:1px solid var(--border);background:var(--bg);display:flex;flex-direction:column;overflow:hidden;min-height:220px;"
>
  {
    coverImage ? (
      <div style="position:relative;height:132px;flex-shrink:0;">
        <img
          src={coverImage}
          alt=""
          width="640"
          height="360"
          loading="lazy"
          decoding="async"
          referrerpolicy="no-referrer-when-downgrade"
          style="width:100%;height:100%;object-fit:cover;display:block;"
        />
        <div
          style="position:absolute;inset:0;background:linear-gradient(to top, rgba(15,23,42,0.82) 0%, rgba(15,23,42,0.15) 55%, transparent 100%);"
        />
        <p
          style="position:absolute;inset-inline:14px;inset-block-end:12px;margin:0;font-weight:900;font-size:1.05rem;color:#f8fafc;text-shadow:0 1px 12px rgba(0,0,0,0.35);"
        >
          {title}
        </p>
      </div>
    ) : (
      <div style="padding:var(--space-5) var(--space-5) 0;">
        <div style="width:72px;height:72px;border-radius:var(--radius-md);overflow:hidden;flex-shrink:0;">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 120 120" width="72" height="72" role="img" aria-hidden="true">
            <defs>
              <linearGradient id={gradId} x1="0" y1="0" x2="1" y2="1">
                <stop offset="0%" stop-color={`hsl(${hue}, 72%, 42%)`} />
                <stop offset="100%" stop-color={`hsl(${(hue + 40) % 360}, 65%, 35%)`} />
              </linearGradient>
            </defs>
            <rect width="120" height="120" fill={`url(#${gradId})`} rx="16" />
            <circle cx="60" cy="52" r="18" fill="white" fill-opacity="0.22" />
            <rect x="34" y="78" width="52" height="10" rx="5" fill="white" fill-opacity="0.35" />
          </svg>
        </div>
        <p style="margin:var(--space-3) 0 0;font-weight:800;font-size:var(--text-lg);">{title}</p>
      </div>
    )
  }
  <div style={`padding: var(--space-4) var(--space-5) var(--space-5); flex: 1; display: flex; flex-direction: column;`}>
    <p style={`margin: ${coverImage ? 0 : "var(--space-2) 0 0"}; color: var(--text-muted); font-size: var(--text-sm); line-height: 1.55; flex: 1;`}>
      {subtitle}
    </p>
    <span style="margin-top:var(--space-3);font-size:var(--text-xs);font-weight:800;color:var(--accent);">ورود به دسته ←</span>
  </div>
</div>

<style>
  .cat-tile {
    transition: transform 0.22s ease, box-shadow 0.22s ease;
  }
  .cat-tile:hover {
    transform: translateY(-4px);
    box-shadow: 0 18px 40px rgba(15, 118, 110, 0.12);
  }
</style>
