---
import CartIsland from "../../islands/CartIsland";
import { getAdminUrl } from "../../lib/admin-url";
import { getSiteSettings } from "../../lib/site-settings";

const adminUrl = getAdminUrl();
const settings = getSiteSettings();
---

<header class="store-header" style="position:sticky;top:0;z-index:40;background:rgba(255,255,255,0.92);backdrop-filter:blur(10px);border-bottom:1px solid var(--border);">
  <div style="max-width:1200px;margin:0 auto;padding:12px var(--space-4);display:flex;align-items:center;gap:var(--space-4);flex-wrap:wrap;">
    <a href="/" style="text-decoration:none;color:inherit;font-weight:900;font-size:1.35rem;letter-spacing:-0.02em;">
      {settings.siteName}
    </a>
    <form
      role="search"
      aria-label="جستجوی محصول"
      style="flex:1;min-width:220px;display:flex;gap:8px;align-items:center;border:1px solid var(--border);border-radius:999px;padding:4px 4px 4px 14px;background:var(--bg-muted);"
      onsubmit="event.preventDefault();"
    >
      <input
        type="search"
        name="q"
        placeholder="دارو، مکمل، تجهیزات پزشکی…"
        style="flex:1;border:none;background:transparent;font:inherit;outline:none;min-width:0;"
      />
      <button
        type="submit"
        style="border:none;border-radius:999px;padding:10px 16px;background:var(--accent);color:var(--accent-foreground);font-weight:700;cursor:pointer;font:inherit;"
      >
        جستجو
      </button>
    </form>
    <nav style="display:flex;align-items:center;gap:var(--space-4);flex-wrap:wrap;">
      <a href="#categories" style="color:var(--text-muted);text-decoration:none;font-size:var(--text-sm);font-weight:600;">دسته‌ها</a>
      <a href="#featured" style="color:var(--text-muted);text-decoration:none;font-size:var(--text-sm);font-weight:600;">پرفروش‌ها</a>
      <a href="/blog" style="color:var(--text-muted);text-decoration:none;font-size:var(--text-sm);font-weight:600;">مجله سلامت</a>
      <a href="/p/about" style="color:var(--text-muted);text-decoration:none;font-size:var(--text-sm);font-weight:600;">درباره</a>
      <a href="/p/contact" style="color:var(--text-muted);text-decoration:none;font-size:var(--text-sm);font-weight:600;">تماس</a>
      <a
        href={adminUrl}
        target="_blank"
        rel="noopener noreferrer"
        style="color:var(--accent);text-decoration:none;font-size:var(--text-sm);font-weight:800;border:1px solid var(--border);padding:8px 14px;border-radius:999px;background:var(--bg);"
      >
        ورود به پنل
      </a>
      <CartIsland client:load />
    </nav>
  </div>
</header>
