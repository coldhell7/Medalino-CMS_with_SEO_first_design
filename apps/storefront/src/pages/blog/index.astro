---
import BaseLayout from "../../layouts/BaseLayout.astro";
import StoreHeader from "../../components/store/StoreHeader.astro";
import StoreFooter from "../../components/store/StoreFooter.astro";
import postsRaw from "@repo/cms/content/posts.json";
import type { CmsPost } from "@repo/cms/types";
import { formatJalaliDate } from "@repo/shared";
import type { WithContext, Blog, ItemList } from "schema-dts";

const posts = postsRaw as CmsPost[];
const published = posts
  .filter((p) => p.status === "publish")
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());

const blogUrl = new URL("/blog", Astro.site).toString();

const blogSchema: WithContext<Blog> = {
  "@context": "https://schema.org",
  "@type": "Blog",
  name: "مجله مدالینو",
  inLanguage: "fa",
  url: blogUrl,
  description: "نوشته‌های منتشرشده از پنل مدیریت محتوا.",
};

const itemList: WithContext<ItemList> = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "آخرین نوشته‌های مجله",
  numberOfItems: published.length,
  itemListElement: published.map((post, i) => ({
    "@type": "ListItem",
    position: i + 1,
    item: {
      "@type": "BlogPosting",
      headline: post.title,
      description: post.excerpt,
      url: new URL(`/blog/${post.slug}`, Astro.site).toString(),
      datePublished: post.date,
    },
  })),
};
---

<BaseLayout
  title="مجله مدالینو"
  canonicalPath="/blog"
  extraLd={[
    blogSchema as unknown as Record<string, unknown>,
    itemList as unknown as Record<string, unknown>,
  ]}
>
  <StoreHeader />
  <main style="max-width:720px;margin:0 auto;padding:var(--space-8);">
    <a href="/" style="color:var(--accent);text-decoration:none;">خانه</a>
    <h1 style="margin-top:var(--space-6);">مجله</h1>
    <p style="color:var(--text-muted);">نوشته‌های منتشرشده از پنل مدیریت محتوا اینجا نمایش داده می‌شوند.</p>
    <ul style="margin:var(--space-8) 0 0;padding:0;list-style:none;display:grid;gap:var(--space-6);">
      {
        published.map((post) => (
          <li>
            <article
              style="padding:0;border:1px solid var(--border);border-radius:var(--radius-lg);overflow:hidden;"
            >
              {post.coverImage ? (
                <img
                  src={post.coverImage}
                  alt={post.title}
                  width="720"
                  height="405"
                  loading="lazy"
                  decoding="async"
                  style="width:100%;aspect-ratio:16/9;object-fit:cover;display:block;"
                />
              ) : null}
              <div style="padding:var(--space-6);">
              <time
                datetime={post.date}
                style="font-size:var(--text-sm);color:var(--text-muted);"
              >
                {formatJalaliDate(post.date, { time: true })}
              </time>
              <h2 style="margin:var(--space-2) 0 var(--space-3);font-size:1.25rem;">
                <a href={`/blog/${post.slug}`} style="color:inherit;text-decoration:none;">
                  {post.title}
                </a>
              </h2>
              <p style="margin:0;color:var(--text-muted);line-height:1.7;">{post.excerpt}</p>
              <a
                href={`/blog/${post.slug}`}
                style="display:inline-block;margin-top:var(--space-4);color:var(--accent);font-weight:700;text-decoration:none;font-size:var(--text-sm);"
              >
                ادامه مطلب
              </a>
              </div>
            </article>
          </li>
        ))
      }
    </ul>
    {published.length === 0 ? (
      <p style="margin-top:var(--space-8);color:var(--text-muted);">هنوز نوشتهٔ منتشرشده‌ای نیست.</p>
    ) : null}
  </main>
  <StoreFooter />
</BaseLayout>
