---
import { getCollection } from "astro:content";
import { getPublishedProducts } from "../data/catalog";
import type { SeoSettings } from "../lib/site-settings";

export const prerender = true;

const siteUrl = Astro.site ? String(Astro.site).replace(/\/$/, "") : "https://medalino.ir";

function nowIso(): string {
  return new Date().toISOString();
}

const publishedProducts = getPublishedProducts();

const staticPaths = [
  { path: "/", changefreq: "daily", priority: 1.0 },
  { path: "/#featured", changefreq: "daily", priority: 0.9 },
];

const productUrls = publishedProducts.map((p) => ({
  path: `/products/${p.slug}`,
  changefreq: "weekly",
  priority: 0.8,
}));

const blogUrls = [
  { path: "/blog", changefreq: "weekly", priority: 0.7 },
];

const allUrls = [...staticPaths, ...productUrls, ...blogUrls];

const xmlUrls = allUrls
  .map((u) => {
    const loc = `${siteUrl}${u.path}`;
    return `  <url>
    <loc>${loc}</loc>
    <lastmod>${nowIso()}</lastmod>
    <changefreq>${u.changefreq}</changefreq>
    <priority>${u.priority}</priority>
  </url>`;
  })
  .join("\n");
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
{xmlUrls}
</urlset>
